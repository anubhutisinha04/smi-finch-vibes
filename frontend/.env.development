# VITE_TILED_TARGET is the real upstream Tiled server the proxy forwards to.
# VITE_TILED_API_URL is the client-facing URL and must point at the local proxy path.
VITE_TILED_TARGET=https://tiled.nsls2.bnl.gov
VITE_TILED_API_URL=http://localhost:5173/api/tiled/api/v1

VITE_OPHYD_API_URL=http://localhost:8001/api/v1
VITE_FINCH_API_URL=http://localhost:8002
VITE_QSERVER_API_URL=http://localhost:60610/api

VITE_QSERVER_API_KEY=test
VITE_API_TILED_API_KEY=a-really-long-key
